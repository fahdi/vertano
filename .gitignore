# Project specific - exclude legacy root JS app files
/src/
public/
/index.html
package*.json
tsconfig*.json
vite.config.ts

# ...but the Astro marketing site under web/ must be tracked (the rules
# above target the abandoned root React app, not web/).
!/web/public/
!/web/public/**
!/web/package.json
!/web/package-lock.json
!/web/tsconfig.json
vitest.config.ts
eslint.config.js

# Test audio (large files)
test-audio/
*.wav
*.mp3
*.m4a
*.ogg
# ...but test fixtures must reach CI (the audio patterns above silently
# excluded these; desktop CI was red from Jul 14 because of it)
!desktop/src-tauri/tests/fixtures/*

# Environment
.env
.env.local

# Swift build artifacts
mac/.build/
mac/dist/
