---
import Base from '../layouts/Base.astro';
---

<Base
  title="Download Vertano free for Mac, Windows, Linux, and Android"
  description="Download Vertano free: native macOS app, Windows installer, Linux AppImage or .deb, and an Android beta APK. Offline batch audio transcription and YouTube caption cleanup. No account, nothing uploaded."
  ogTitle="Download Vertano"
  ogDescription="Free on Mac, Windows, Linux, and Android. Offline transcription and caption cleanup, nothing uploaded."
>
  <div class="wrap">
    <section>
      <div class="sec-label rv">Download</div>
      <h1 class="rv">Enter it into the record.</h1>
      <p class="lede rv" style="margin-top:18px">Free on every desktop. Your platform is highlighted below.</p>

      <a class="gh-banner rv" href="/app/">
        <b>No install</b>
        <span>Don't want to install anything? <u>Try Vertano in your browser</u>. Same on-device privacy, nothing uploaded, ever.</span>
      </a>

      <div class="dl-cards rv">
        <div class="dl" id="dl-mac">
          <div class="dl-os"><h3>macOS</h3><span class="dl-badge live">Available</span></div>
          <p>Native Swift app, Metal-accelerated, with in-app live recording.</p>
          <a class="btn btn-primary" id="mac-link" href="https://github.com/fahdi/vertano/releases/download/v0.3.0/StenoDrop-0.3.0-macos.zip">↓ Download</a>
          <span class="dl-note">Unsigned beta: right-click → Open the first time.</span>
        </div>
        <div class="dl" id="dl-win">
          <div class="dl-os"><h3>Windows</h3><span class="dl-badge live" id="win-badge">Available</span></div>
          <p>Windows 10/11 installer. Your audio never leaves the machine.</p>
          <a class="btn btn-primary" id="win-link" href="https://github.com/fahdi/vertano/releases/download/v0.3.0/StenoDrop_0.3.0_x64-setup.exe">↓ Download</a>
          <span class="dl-note">SmartScreen may warn on unsigned betas. Click “More info,” then “Run anyway.”</span>
        </div>
        <div class="dl" id="dl-linux">
          <div class="dl-os"><h3>Linux</h3><span class="dl-badge live" id="linux-badge">Available</span></div>
          <p>AppImage or .deb. If your distro can play a sound, it can transcribe one.</p>
          <a class="btn btn-primary" id="linux-link" href="https://github.com/fahdi/vertano/releases/download/v0.3.0/StenoDrop_0.3.0_amd64.AppImage">↓ Download</a>
          <span class="dl-note">chmod +x and run it, or grab the <a id="deb-link" href="https://github.com/fahdi/vertano/releases/download/v0.3.0/StenoDrop_0.3.0_amd64.deb">.deb</a> instead.</span>
        </div>
        <div class="dl" id="dl-android">
          <div class="dl-os"><h3>Android</h3><span class="dl-badge live">Beta APK</span></div>
          <p>Android 8+. Pick a folder, transcripts land beside your audio, all on-device.</p>
          <a class="btn btn-primary" id="android-link" href="https://github.com/fahdi/stenodrop-android/releases/download/v0.1.4/StenoDrop-0.1.4-android.apk">↓ Download</a>
          <span class="dl-note">Sideload: allow “Install unknown apps”. Play Store listing coming.</span>
        </div>
      </div>
      <p class="rv" style="margin-top:14px;font-size:13px;font-family:var(--mono);color:var(--dim)">Vertano is the new name for StenoDrop. Downloads are still labeled StenoDrop while the rename rolls out; everything keeps working through the change.</p>
      <div class="dl-soon rv"><b>Coming soon</b><span>Vertano for iPhone is on its way, with the same promise: on-device, private, and free. Watch <a href="https://github.com/fahdi/vertano-ios">vertano-ios</a> for the announcement.</span></div>

      <div class="install-grid rv">
        <div>
          <div class="appendix-label">Appendix A: macOS prerequisites</div>
          <div class="term">
            <div class="term-head"><span>engine install</span><button class="term-copy" data-copy="brew install whisper-cpp ffmpeg">copy</button></div>
            <pre><span class="c"># free engine + audio converter</span>
brew install whisper-cpp ffmpeg

<span class="c"># unsigned beta, clear quarantine once</span>
xattr -cr /Applications/Vertano.app</pre>
          </div>
          <p class="install-note">First launch offers a one-click download of the voice-recognition software (about 466&nbsp;MB). After that, you're fully offline. Windows and Linux builds bundle everything already, so there's nothing extra to install.</p>
        </div>
        <div>
          <div class="appendix-label">Appendix B: build from source</div>
          <div class="term">
            <div class="term-head"><span>any platform</span><button class="term-copy" data-copy="git clone https://github.com/fahdi/vertano.git && cd vertano/mac && ./scripts/make-app.sh">copy</button></div>
            <pre>git clone https://github.com/fahdi/vertano.git
<span class="c"># macOS (Swift):</span>
cd vertano/mac &amp;&amp; ./scripts/make-app.sh
<span class="c"># Windows / Linux (Tauri + Rust):</span>
cd vertano/desktop &amp;&amp; cargo tauri build</pre>
          </div>
          <p class="install-note">Open source. Audit it, fork it, or send a pull request. The <a href="https://github.com/fahdi/vertano">repository</a> has build docs for every platform.</p>
        </div>
      </div>
    </section>
  </div>

  <script is:inline>
    // Highlight the visitor's OS.
    (function(){
      const ua=navigator.userAgent, p=navigator.platform||'';
      let id='dl-mac';
      if(/Android/i.test(ua))id='dl-android';
      else if(/Win/i.test(p)||/Windows/i.test(ua))id='dl-win';
      else if(/Linux/i.test(p))id='dl-linux';
      document.getElementById(id)?.classList.add('detected');
    })();

    // Keep download links pointed at each repo's actual latest release, so
    // the buttons never drift from what is published. href only.
    function wireLatestRelease(repo, linkId, pick){
      fetch(`https://api.github.com/repos/${repo}/releases/latest`)
        .then(r=>r.ok?r.json():null)
        .then(rel=>{
          const asset = rel && rel.assets && pick(rel.assets);
          if(asset && document.getElementById(linkId)) document.getElementById(linkId).href = asset.browser_download_url;
        }).catch(()=>{});
    }
    wireLatestRelease('fahdi/vertano', 'mac-link', a => a.find(x=>/\.zip$/i.test(x.name)));
    wireLatestRelease('fahdi/vertano', 'win-link', a => a.find(x=>/\.(exe|msi)$/i.test(x.name)));
    wireLatestRelease('fahdi/vertano', 'linux-link', a => a.find(x=>/\.AppImage$/i.test(x.name)));
    wireLatestRelease('fahdi/vertano', 'deb-link', a => a.find(x=>/\.deb$/i.test(x.name)));
    wireLatestRelease('fahdi/stenodrop-android', 'android-link', a => a.find(x=>/\.apk$/i.test(x.name)));
  </script>
</Base>
