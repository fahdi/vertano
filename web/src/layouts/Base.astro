---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  /** JSON-LD object injected as-is; each page supplies its own. */
  schema?: Record<string, unknown>;
  ogTitle?: string;
  ogDescription?: string;
}
const { title, description, schema, ogTitle, ogDescription } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const path = Astro.url.pathname;
const nav = [
  { href: '/features/', label: 'Features' },
  { href: '/youtube-captions/', label: 'YouTube Captions' },
  { href: '/languages/', label: 'Languages' },
  { href: '/download/', label: 'Download' },
  { href: '/app/', label: 'Try Online' },
  { href: 'https://github.com/fahdi/vertano', label: 'GitHub' },
];
const isActive = (href: string) => href.startsWith('/') && path.startsWith(href);
---

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
<meta property="og:title" content={ogTitle ?? title} />
<meta property="og:description" content={ogDescription ?? description} />
<meta property="og:type" content="website" />
<meta property="og:url" content={canonical} />
<meta property="og:image" content="https://vertano.app/og.png" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={ogTitle ?? title} />
<meta name="twitter:description" content={ogDescription ?? description} />
<meta name="twitter:image" content="https://vertano.app/og.png" />
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="sitemap" href="/sitemap-index.xml" />
{schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
<meta name="theme-color" content="#FAF7F0" />
<script is:inline>
// Stamp html.js so the reveal's hidden state only applies with JS present
// (no-JS and crawlers get full content).
document.documentElement.classList.add('js');
// Theme before first paint: manual choice wins, else day/night by local clock.
(function(){
  var saved=null;try{saved=localStorage.getItem('sd-theme')}catch(e){}
  var h=new Date().getHours();
  var auto=(h>=7&&h<19)?'light':'dark';
  document.documentElement.dataset.theme=saved||auto;
})();
</script>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Besley:ital,wght@0,400;0,700;0,900;1,400;1,900&family=Courier+Prime:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />
</head>
<body>

<header>
  <div class="wrap head-in">
    <a class="brand" href="/">
      <svg viewBox="0 0 128 128" aria-hidden="true"><rect width="128" height="128" rx="28" fill="#17150F"/><path fill="#FAF7F0" d="M8 122 C10 103 24 95 35 91.5 C37.5 90.6 38.5 88.5 38.5 85 C31 79 25.5 69 25 57 C24.3 37 35 19.5 52 18.2 C61.5 17.6 69.8 23.2 71.8 31 C72.7 34.6 72.5 37.6 71.6 40 L78 48.8 C79 50.4 78.2 51.8 76.2 52 L70.9 52.5 C70.4 54 71 54.8 73 55.4 L74.6 56.6 L64.8 59.6 L72.6 63 C72.6 64.9 71.3 66.2 69 66.8 C69.6 69.8 68 72.9 64.4 74.9 C62.2 76.1 60 77.8 57.9 79.1 C56.3 83.6 56 87.6 56.5 91.5 C70 95.5 78.6 104 80.5 122 Z"/><g stroke="#FAF7F0" stroke-width="4" stroke-linecap="round" fill="none"><path d="M86 50 L97 43"/><path d="M88 60.5 L103 60.5"/><path d="M86 71 L97 78"/></g><g stroke-linecap="round" fill="none"><path d="M86 88 C94 85.8 104 86.6 118 85.6" stroke="#FAF7F0" stroke-width="4.6"/><path d="M86 99 C96 96.8 106 98 116 96.8" stroke="#FAF7F0" stroke-width="4.6"/><path d="M86 110 C92 108.2 98 109.2 104 108.2" stroke="#B3261E" stroke-width="4.6"/></g></svg>
      Vertano
    </a>
    <nav class="nav">
      {nav.map((n) => (
        <a href={n.href} aria-current={isActive(n.href) ? 'page' : undefined} {...(n.href.startsWith('http') ? { rel: 'noopener' } : {})}>{n.label}</a>
      ))}
      <button class="theme-btn" id="theme-btn" aria-live="polite"></button>
    </nav>
  </div>
  <div class="wrap"><div class="case-line">
    <span>IN THE MATTER OF: YOUR UNREAD AUDIO</span>
    <span>CASE NO. ∞ VOICE MEMOS</span>
    <span>FILED: LOCALLY, ALWAYS</span>
  </div></div>
</header>

<slot />

<footer>
  <div class="wrap">
    <div class="cert rv">
      <p>I hereby certify that the foregoing software is free of charge, free of accounts, and free of telemetry; that audio processed by it remains on the machine of the operator; and that the transcripts produced are entered as .txt beside their sources.</p>
      <p class="sig">Vertano</p>
    </div>
    <div class="foot">
      <span>Vertano. Free, offline, batch transcription.</span>
      <span><a href="/app/">Try it online</a> · <a href="https://github.com/fahdi/vertano">GitHub</a> · <a href="https://github.com/fahdi/vertano/issues">Issues</a> · built on <a href="https://github.com/ggerganov/whisper.cpp">whisper.cpp</a></span>
      <span>made by <a href="https://fahdmurtaza.com">Fahd Murtaza</a></span>
    </div>
  </div>
</footer>

<script is:inline>
// reveals
const io=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target)}}),{threshold:.12});
document.querySelectorAll('.rv').forEach(el=>io.observe(el));

// copy buttons
document.querySelectorAll('.term-copy').forEach(b=>b.addEventListener('click',()=>{
  navigator.clipboard.writeText(b.dataset.copy).then(()=>{const t=b.textContent;b.textContent='copied ✓';setTimeout(()=>b.textContent=t,1400)});
}));

// theme toggle: manual override persists; returning to the auto value clears it
const themeBtn=document.getElementById('theme-btn');
const autoTheme=()=>{const h=new Date().getHours();return(h>=7&&h<19)?'light':'dark'};
function paintTheme(){
  const t=document.documentElement.dataset.theme;
  themeBtn.textContent=t==='dark'?'☾':'☀';
  const label='Switch to '+(t==='dark'?'day':'night')+' theme';
  themeBtn.setAttribute('aria-label',label);
  themeBtn.setAttribute('title',label);
  document.querySelector('meta[name="theme-color"]').setAttribute('content',t==='dark'?'#141209':'#FAF7F0');
}
themeBtn.addEventListener('click',()=>{
  const next=document.documentElement.dataset.theme==='dark'?'light':'dark';
  document.documentElement.dataset.theme=next;
  try{next===autoTheme()?localStorage.removeItem('sd-theme'):localStorage.setItem('sd-theme',next)}catch(e){}
  paintTheme();
});
paintTheme();
</script>
</body>
</html>
